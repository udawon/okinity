# 배포 도메인 (OG·sitemap 절대 URL 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://ponyokinawa.com

# 예약 문의 이메일 발송 (Resend) — 설정 안 하면 콘솔 로그로 대체(로컬 개발)
# https://resend.com 에서 API 키 발급
RESEND_API_KEY=
# 문의를 받을 강사 이메일 (gating 결정 #2)
INQUIRY_TO_EMAIL=
# 발신 주소 (Resend 인증된 도메인 또는 onboarding@resend.dev)
INQUIRY_FROM_EMAIL=onboarding@resend.dev

# ── 어드민 (/admin) ──────────────────────────────────────────────
# 어드민 로그인 비밀번호 (필수 — 미설정 시 어드민 로그인 불가)
ADMIN_PASSWORD=
# 세션 쿠키 서명 비밀키 (운영에서는 반드시 임의의 긴 문자열로 설정)
# 예: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# ── 문의 저장소 ──────────────────────────────────────────────────
# 미설정 시: JSON 파일(.data/inquiries.json)에 저장 — 로컬/단일서버 전용.
#   ⚠ Vercel 서버리스는 파일이 휘발성이라 프로덕션에서 데이터가 사라집니다.
# Postgres 연결 문자열을 설정하면 자동으로 Postgres 사용(영속).
#   Neon / Vercel Postgres / Supabase 등의 연결 문자열.
POSTGRES_URL=

# ── 콘텐츠/미디어 CMS (Supabase) ──────────────────────────────────
# 어드민에서 편집한 영역별 콘텐츠/이미지/동영상을 저장.
# 미설정 시: 어드민 콘텐츠 편집 비활성 + 메인은 content/*.md 기본값만 사용(정상 동작).
# supabase.com → 프로젝트 생성 → Project Settings > API 에서 발급.
# Project URL (예: https://xxxx.supabase.co)
SUPABASE_URL=
# service_role 키 (서버 전용 — DB 읽기/쓰기 + Storage 업로드). 절대 클라이언트 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=
# Storage 버킷 이름 (기본 media). public 버킷으로 생성.
SUPABASE_MEDIA_BUCKET=media
